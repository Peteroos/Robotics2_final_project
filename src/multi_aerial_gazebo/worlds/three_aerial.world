          </geometry>
          <material>
            <ambient>0.65 0.75 0.90 1.0</ambient>
            <diffuse>0.65 0.75 0.90 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="simple_block_2">
      <static>true</static>
      <pose>-2.2 -2.4 0.75 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>1.0 1.8 1.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>1.0 1.8 1.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0.90 0.78 0.65 1.0</ambient>
